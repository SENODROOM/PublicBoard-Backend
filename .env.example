# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/publicboard?retryWrites=true&w=majority
 
# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_random_hex_string
JWT_REFRESH_SECRET=replace_with_different_64_byte_random_hex_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
 
# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
 
# ── CORS — comma-separated list of allowed frontend origins ───────────────────
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
 
# ── Stripe (real payment processing) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
 
# ── Email (Resend — transactional email) ──────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com
FRONTEND_URL=https://yourdomain.com
 
# ── Admin Seed ────────────────────────────────────────────────────────────────
# IMPORTANT: Change these before first deployment. Remove from .env after first run.
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMe@12345
ADMIN_NAME=Super Admin